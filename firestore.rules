rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Profesionales: solo acceden a sus propios datos y subcolecciones
    match /professionals/{professionalId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == professionalId;
    }

    // Vínculos paciente-profesional: cada paciente solo ve el suyo
    match /patient_links/{patientId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == patientId;
    }

  }
}
