# Renombrar a .env y completar con tus valores

# Firebase Admin SDK - descargar JSON desde Firebase Console > Project Settings > Service accounts
FIREBASE_CREDENTIALS_PATH=./firebase-adminsdk.json

# Ollama - URL del servidor local
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3

# Whisper - modelo a usar (tiny, base, small, medium, large)
WHISPER_MODEL=base

# CORS - origen del frontend Angular en desarrollo
FRONTEND_URL=http://localhost:4200

# Resend - servicio de email (https://resend.com, free tier: 3000 emails/mes)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Remitente verificado (en sandbox de Resend usá onboarding@resend.dev)
EMAIL_FROM=SecretarIA <onboarding@resend.dev>
